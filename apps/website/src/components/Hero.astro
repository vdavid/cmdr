---
import DownloadButton from './DownloadButton.astro'

const currentYear = new Date().getFullYear()
---

<section class="hero-section relative overflow-hidden px-6 pt-16 md:px-12 lg:px-20">
    <!-- Background gradient -->
    <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(255,194,6,0.15),transparent)]"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
        class="pointer-events-none absolute inset-0 bg-[linear-gradient(var(--color-border-subtle)_1px,transparent_1px),linear-gradient(90deg,var(--color-border-subtle)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,black,transparent)]"
    >
    </div>

    <div class="hero-content relative z-10 pt-16 text-left md:pt-24">
        <!-- Open-beta eyebrow - Step 1 -->
        <a
            href="/feature-status"
            class="animate-blur-in stagger-1 mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-sm font-medium text-[var(--color-accent-text)] transition-colors hover:bg-[var(--color-accent)]/20"
        >
            Now in open beta
            <span aria-hidden="true">&rarr;</span>
        </a>

        <!-- Headline - Steps 2 & 3 -->
        <h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-6xl">
            <span class="animate-blur-in stagger-2 inline-block">Finally, a file manager</span>
            <span class="animate-blur-in stagger-3 inline-block gradient-text">from {currentYear}!</span>
        </h1>

        <!-- Subheadline - Step 4 -->
        <p
            class="animate-blur-in stagger-4 mb-10 max-w-xl text-lg leading-relaxed text-[var(--color-text-secondary)] md:text-xl"
        >
            Indexes your whole drive in minutes. Instant search, visible folder sizes, keyboard-driven everything.
            Built in Rust, free for personal use.
        </p>

        <!-- CTA Button - Step 5 -->
        <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-stretch">
            <DownloadButton variant="hero" class="animate-blur-in stagger-5 w-full sm:w-auto" />
        </div>

        <!-- Pricing hint - Step 7 -->
        <p class="animate-blur-in stagger-7 mt-8 text-sm text-[var(--color-text-tertiary)]">
            Source-available · Free forever for personal use · Commercial from $59/year
        </p>
    </div>

    <!-- Hero illustration with 3D perspective -->
    <div class="hero-illustration" aria-hidden="true">
        <div class="hero-perspective">
            <div class="hero-base">
                <!-- Layers are CSS background images (not <img>): the preload scanner downloads every
                     <img> even inside display:none, so <img> would fetch both theme variants (~2x the
                     bytes). Background images only load for rendered elements, and image-set() picks
                     the 1x/2x file by device pixel ratio. -->
                <!-- Dark variant -->
                <div class="hero-variant hero-variant--dark">
                    <div class="hero-layer hero-frame"></div>
                    <div class="hero-layer hero-right-pane"></div>
                    <div class="hero-layer hero-left-pane"></div>
                </div>
                <!-- Light variant -->
                <div class="hero-variant hero-variant--light">
                    <div class="hero-layer hero-frame"></div>
                    <div class="hero-layer hero-right-pane"></div>
                    <div class="hero-layer hero-left-pane"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Text blur-in animation - global so it applies to classes */
    :global(.animate-blur-in) {
        animation: blur-in 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    /* Stagger delays for 7-step animation (100ms apart, overlapping) */
    :global(.stagger-1) {
        animation-delay: 0ms;
    }
    :global(.stagger-2) {
        animation-delay: 100ms;
    }
    :global(.stagger-3) {
        animation-delay: 200ms;
    }
    :global(.stagger-4) {
        animation-delay: 300ms;
    }
    :global(.stagger-5) {
        animation-delay: 400ms;
    }
    :global(.stagger-6) {
        animation-delay: 500ms;
    }
    :global(.stagger-7) {
        animation-delay: 600ms;
    }

    @keyframes blur-in {
        from {
            opacity: 0;
            filter: blur(10px);
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            filter: blur(0);
            transform: translateY(0);
        }
    }

    .hero-section {
        min-height: 100vh;
        position: relative;
    }

    /* Gradient overlay at bottom - covers full width including padding */
    .hero-section::after {
        content: '';
        pointer-events: none;
        z-index: 5;
        background: linear-gradient(to bottom, transparent 50%, var(--color-background) 100%);
        position: absolute;
        inset: 0;
    }

    .hero-content {
        position: relative;
        z-index: 10;
    }

    .hero-illustration {
        pointer-events: none;
        user-select: none;
        width: 100%;
        position: relative;
        margin-top: -200px;
        margin-left: -100px;
    }

    @media (max-width: 767px) {
        .hero-illustration {
            height: 600px;
            margin-top: 0;
            margin-left: -40px;
        }
    }

    .hero-perspective {
        perspective: 4000px;
        perspective-origin: 100% 0;
    }

    .hero-base {
        transform-origin: 0 0;
        backface-visibility: hidden;
        width: 1600px;
        height: 900px;
        margin: 280px auto auto;
        position: absolute;
        top: 0;
        bottom: 0;
        left: -100px;
        right: 0;
        transform: translate(2%) scale(1.2) rotateX(47deg) rotateY(31deg) rotate(324deg);
    }

    @media (max-width: 767px) {
        .hero-base {
            margin-top: 100px;
            margin-left: 1%;
            transform: scale(0.7) rotateX(47deg) rotateY(21deg) rotate(330deg);
        }
    }

    /* Scale hero image on large screens */
    @media (min-width: 1700px) {
        .hero-base {
            width: 94vw;
            height: calc(94vw * 9 / 16);
        }
    }

    /* Variant containers fill the hero-base and stack on top of each other */
    .hero-variant {
        position: absolute;
        inset: 0;
    }

    /* Default: show dark, hide light */
    .hero-variant--light {
        display: none;
    }

    /* System light preference, no explicit dark override */
    @media (prefers-color-scheme: light) {
        :global(:root:not([data-theme='dark'])) .hero-variant--dark {
            display: none;
        }
        :global(:root:not([data-theme='dark'])) .hero-variant--light {
            display: block;
        }
    }

    /* Explicit light override */
    :global(:root[data-theme='light']) .hero-variant--dark {
        display: none;
    }
    :global(:root[data-theme='light']) .hero-variant--light {
        display: block;
    }

    .hero-layer {
        position: absolute;
        inset: 0;
        background-position: center;
        background-repeat: no-repeat;
        background-size: contain;
    }

    /* The -webkit-image-set() fallbacks cover Safari < 17, which only knows the prefixed form. */
    .hero-variant--dark .hero-frame {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-frame-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-frame-dark.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-frame-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-frame-dark.webp') 2x
        );
    }

    .hero-variant--dark .hero-left-pane {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-left-pane-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-left-pane-dark.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-left-pane-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-left-pane-dark.webp') 2x
        );
    }

    .hero-variant--dark .hero-right-pane {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-right-pane-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-right-pane-dark.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-right-pane-dark-1x.webp') 1x,
            url('/hero/cmdr-hero-right-pane-dark.webp') 2x
        );
    }

    .hero-variant--light .hero-frame {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-frame-light-1x.webp') 1x,
            url('/hero/cmdr-hero-frame-light.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-frame-light-1x.webp') 1x,
            url('/hero/cmdr-hero-frame-light.webp') 2x
        );
    }

    .hero-variant--light .hero-left-pane {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-left-pane-light-1x.webp') 1x,
            url('/hero/cmdr-hero-left-pane-light.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-left-pane-light-1x.webp') 1x,
            url('/hero/cmdr-hero-left-pane-light.webp') 2x
        );
    }

    .hero-variant--light .hero-right-pane {
        background-image: -webkit-image-set(
            url('/hero/cmdr-hero-right-pane-light-1x.webp') 1x,
            url('/hero/cmdr-hero-right-pane-light.webp') 2x
        );
        background-image: image-set(
            url('/hero/cmdr-hero-right-pane-light-1x.webp') 1x,
            url('/hero/cmdr-hero-right-pane-light.webp') 2x
        );
    }

    /* Gradient fade on right edge. Stops include a `+ 10vw` term so wider viewports
       reveal ~10 percentage points more of the image without a breakpoint hop. */
    .hero-frame,
    .hero-left-pane,
    .hero-right-pane {
        mask-image: linear-gradient(
            to right,
            black 0%,
            black calc(50% + 10vw),
            transparent calc(80% + 10vw)
        );
    }

    /* Frame - visible immediately with subtle blur-in */
    .hero-frame {
        opacity: 0;
        animation: hero-image-in 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* Right pane - animates in first (blur + translate) */
    .hero-right-pane {
        opacity: 0;
        animation: hero-image-in 2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    }

    /* Left pane - animates in second */
    .hero-left-pane {
        opacity: 0;
        animation: hero-image-in 2s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
    }

    @keyframes hero-image-in {
        0% {
            opacity: 0;
            filter: blur(10px);
            transform: translate(165%, 200%);
        }
        100% {
            opacity: 1;
            filter: none;
            transform: none;
        }
    }

    /* Degrade to opacity-only fade under reduced motion */
    @keyframes fade-in-only {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        :global(.animate-blur-in) {
            animation: fade-in-only 0.5s ease both;
            filter: none;
            transform: none;
        }

        .hero-frame,
        .hero-right-pane,
        .hero-left-pane {
            animation: fade-in-only 0.8s ease both;
            filter: none;
            transform: none;
        }
    }
</style>
