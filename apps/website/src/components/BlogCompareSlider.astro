<!-- Drives the before/after comparison sliders emitted by rehypeBlogMedia (`.img-compare`). The
     divider follows the pointer (accounting for the slant via the cursor's Y), the overlaid range
     gives keyboard control, and an expand button opens the lightbox `<dialog>`. The slant is
     position-dependent: vertical at the left, leaning "/" up to ~30° to the right at the right edge.
     Geometry (clip + divider rotation) lives in global.css; this only sets --reveal/--slant and the
     divider rotation, and opens/closes the dialog. -->
<script>
    const SLANT_MAX = 18 // half-width % of the wipe at the far right; ~30° at the slider's aspect.

    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll<HTMLElement>('[data-img-compare]').forEach((root) => {
            if (root.dataset.compareReady) return
            root.dataset.compareReady = '1'

            const range = root.querySelector<HTMLInputElement>('.img-compare__range')
            const lightbox = root.querySelector<HTMLDialogElement>('[data-img-compare-lightbox]')
            const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
            let dragging = false

            // Apply a divider position. --reveal is the mid-height seam position (NOT clamped to 0–100:
            // the slant needs it slightly outside that to reach corners). --slant grows with position so
            // the seam is vertical at the left and leans ~30° at the right; the divider's rotation is
            // derived from --slant and the box's aspect so the bar matches the clipped seam exactly.
            const apply = (reveal: number, slant: number, rect: DOMRect) => {
                const angle = (Math.atan(((2 * slant) / 100) * (rect.width / rect.height)) * 180) / Math.PI
                root.style.setProperty('--reveal', String(reveal))
                root.style.setProperty('--slant', String(slant))
                root.style.setProperty('--divider-rot', `${angle}deg`)
                if (range) {
                    const value = String(Math.max(0, Math.min(100, Math.round(reveal))))
                    if (range.value !== value) range.value = value
                }
            }

            // Slant scales with the cursor's horizontal position; solve for the reveal whose slanted
            // edge passes through the cursor at its Y. Clamp the cursor (not the reveal) to the box.
            const revealFromPointer = (clientX: number, clientY: number) => {
                const rect = root.getBoundingClientRect()
                if (rect.width <= 0 || rect.height <= 0) return
                const cx = Math.max(0, Math.min(100, ((clientX - rect.left) / rect.width) * 100))
                const cy = Math.max(0, Math.min(1, (clientY - rect.top) / rect.height))
                const slant = (SLANT_MAX * cx) / 100
                apply(cx + slant * (2 * cy - 1), slant, rect)
            }

            root.addEventListener('pointerdown', (event) => {
                if (lightbox?.open) return
                if ((event.target as HTMLElement).closest('.img-compare__expand, .img-compare__lightbox')) return
                dragging = true
                root.setPointerCapture?.(event.pointerId)
                revealFromPointer(event.clientX, event.clientY)
            })
            const endDrag = () => {
                dragging = false
            }
            root.addEventListener('pointerup', endDrag)
            root.addEventListener('pointercancel', endDrag)
            // On a pointer device the divider follows hover; with reduced motion it only moves while
            // dragging. Frozen entirely while the lightbox is open.
            root.addEventListener('pointermove', (event) => {
                if (lightbox?.open) return
                if (!reduceMotion || dragging) revealFromPointer(event.clientX, event.clientY)
            })
            range?.addEventListener('input', () => {
                const rect = root.getBoundingClientRect()
                const reveal = Number(range.value)
                apply(reveal, (SLANT_MAX * reveal) / 100, rect)
            })

            const expand = root.querySelector<HTMLButtonElement>('[data-img-compare-expand]')
            const close = root.querySelector<HTMLButtonElement>('[data-img-compare-close]')
            expand?.addEventListener('click', () => lightbox?.showModal())
            close?.addEventListener('click', () => lightbox?.close())
            // Close on backdrop click (the dialog element itself, outside its content).
            lightbox?.addEventListener('click', (event) => {
                if (event.target === lightbox) lightbox.close()
            })
        })
    })
</script>
