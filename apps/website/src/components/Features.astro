---
import StatusPill from './StatusPill.astro'
import Icon from './icons/Icon.astro'
import type { IconName } from './icons/icon-map'
import { getFeature, type FeatureStatus } from '../lib/feature-status'

const shipped = [
    {
        slug: 'full-disk-index',
        icon: 'database',
        title: 'Live full-disk index',
        description:
            'Indexes <em>your entire drive</em> in 4 minutes. Once. Then stays current forever, even across restarts.',
    },
    {
        slug: 'local-ai',
        icon: 'sparkles',
        title: 'Private LLM included',
        description:
            'Comes with an on-device model for local, private use. Bring your own OpenAI/Anthropic/etc. API key for smarter results.',
    },
    {
        slug: 'file-explorer',
        icon: 'rocket',
        title: 'Really, really fast',
        description:
            'Built in Rust. Opens a 100k-file folder in 4 seconds with icons, sizes, and dates, cold. In 1 second when warm.',
    },
    {
        slug: 'keyboard-shortcuts',
        icon: 'keyboard',
        title: 'Keyboard-first',
        description:
            'Kb-first navigate, select, copy, move, rename; menus, tabs, settings; command palette. But works with a mouse, too.',
    },
] satisfies { slug: string; icon: IconName; title: string; description: string }[]

const upcoming = [
    {
        slug: 'search',
        icon: 'search',
        title: 'Smart search',
        description: 'Find files by saying: "that PDF contract from last month" or "all my node_modules folders"',
        status: getFeature('search')?.status,
    },
    {
        slug: 'ai-rename',
        icon: 'brain',
        title: 'Natural language rename',
        description: 'Commands like "make these files lowercase and add date prefix". No regex, no scripts.',
        status: getFeature('ai-rename')?.status,
    },
    {
        slug: 'ai-batch',
        icon: 'zap',
        title: 'AI file organization',
        description:
            'Say "Clean up my Downloads folder" to get a list of move/delete suggestions you can approve/reject.',
        status: getFeature('ai-batch')?.status,
    },
] satisfies { slug: string; icon: IconName; title: string; description: string; status: FeatureStatus | undefined }[]
---

<section id="features" class="relative px-6 py-32">
    <div class="mx-auto max-w-6xl">
        <!-- Section header -->
        <div class="mb-16 text-center">
            <h2 class="mb-4 text-3xl font-bold md:text-4xl lg:text-5xl">
                Built for <span class="gradient-text">power users</span>
            </h2>
            <p class="mx-auto max-w-2xl text-lg text-[var(--color-text-secondary)]">
                Unimaginably fast, keyboard-driven, and gets smarter every week.
            </p>
        </div>

        <!-- Shipped features -->
        <div class="grid gap-6 md:grid-cols-2">
            {
                shipped.map((feature) => (
                    <a
                        href={`/features#${feature.slug}`}
                        class="group relative block rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 no-underline transition-all duration-300 hover:border-[var(--color-accent)]/30 hover:bg-[var(--color-surface-elevated)]"
                    >
                        <Icon name={feature.icon} size={40} class="mb-4" />
                        <h3 class="mb-2 text-xl font-semibold">{feature.title}</h3>
                        <p class="text-[var(--color-text-secondary)]" set:html={feature.description} />
                    </a>
                ))
            }
        </div>

        <!-- AI features separator -->
        <p class="my-10 text-center text-sm font-medium tracking-wide text-[var(--color-text-tertiary)] uppercase">
            Fresh and upcoming
        </p>

        <!-- Upcoming AI features -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
                upcoming.map((feature) => (
                    <a
                        href={`/features#${feature.slug}`}
                        class="group relative block rounded-2xl border border-[var(--color-accent)]/30 bg-gradient-to-br from-[var(--color-surface)] to-[var(--color-accent)]/5 p-8 no-underline transition-all duration-300 hover:border-[var(--color-accent)]/50"
                    >
                        {feature.status && (
                            <span class="absolute top-4 right-4">
                                <StatusPill status={feature.status} link={false} />
                            </span>
                        )}
                        <Icon name={feature.icon} size={40} class="mb-4" />
                        <h3 class="mb-2 text-xl font-semibold">{feature.title}</h3>
                        <p class="text-[var(--color-text-secondary)]" set:html={feature.description} />
                    </a>
                ))
            }
        </div>
    </div>
</section>
