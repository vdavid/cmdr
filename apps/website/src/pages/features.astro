---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import DownloadButton from '../components/DownloadButton.astro'
import NewsletterInlineWrapper from '../components/NewsletterInlineWrapper.astro'
import StatusPill from '../components/StatusPill.astro'
import { features, type Feature } from '../lib/feature-status'

/**
 * Presentation map over the repo-root `feature-status.json`: one flat bento grid, no
 * sections. Each card carries a yellow category chip and a cyan status pill; flagship
 * cards span two columns with a trimmed blurb, the rest render the JSON's honest
 * one-line note. The completeness check below fails the build when the JSON and this
 * map drift, so a new feature can't silently miss the page.
 */
interface CardSpec {
    id: string
    category: 'Find stuff' | 'AI' | 'Core' | 'Keyboard' | 'Connect' | 'Extras'
    icon: string
    flagship?: boolean
    /** Marketing title override; defaults to the JSON name. */
    title?: string
    /** Flagship-only: 2-3 sentence blurb. Non-flagship cards render the JSON note. */
    blurb?: string
}

const cards: CardSpec[] = [
    // Three highlights up top (the only flagship-width cards), each paired with a related
    // small card that fills the third column.
    {
        id: 'full-disk-index',
        category: 'Find stuff',
        icon: '/icons/database.svg',
        flagship: true,
        title: 'Live full-disk index',
        blurb: 'Indexes your whole drive in ~4 minutes, then stays current by watching real-time file system events. Folder sizes show right in the listing, and a background verifier makes sure they don\'t drift.',
    },
    { id: 'go-to-path', category: 'Find stuff', icon: '/icons/navigation.svg' },
    {
        id: 'search',
        category: 'Find stuff',
        icon: '/icons/search.svg',
        flagship: true,
        title: 'Smart search',
        blurb: 'Find files like "that PDF contract from last month". AI turns it into filters, see hits in a second.',
    },
    { id: 'select-files', category: 'Core', icon: '/icons/list-checks.svg' },
    {
        id: 'local-ai',
        category: 'AI',
        icon: '/icons/sparkles.svg',
        flagship: true,
        title: 'Private LLM included',
        blurb: 'Cmdr ships with a 3B language model that runs on your Mac. Nothing leaves your machine. For a smarter AI, you can connect OpenAI/Anthropic/Google/etc., or any OpenAI-compatible endpoint.',
    },
    { id: 'ai-rename', category: 'AI', icon: '/icons/brain.svg' },
    // Core
    { id: 'file-explorer', category: 'Core', icon: '/icons/folder.svg' },
    { id: 'file-operations', category: 'Core', icon: '/icons/copy.svg' },
    { id: 'file-viewer', category: 'Core', icon: '/icons/eye.svg' },
    { id: 'tabs', category: 'Core', icon: '/icons/app-window.svg' },
    { id: 'drag-and-drop', category: 'Core', icon: '/icons/pointer.svg' },
    { id: 'archives', category: 'Core', icon: '/icons/file-archive.svg' },
    // Details: keyboard + connectivity
    { id: 'keyboard-shortcuts', category: 'Keyboard', icon: '/icons/keyboard.svg' },
    { id: 'command-palette', category: 'Keyboard', icon: '/icons/square-chevron-right.svg' },
    { id: 'network-drives', category: 'Connect', icon: '/icons/server.svg' },
    { id: 'android-devices', category: 'Connect', icon: '/icons/smartphone.svg' },
    { id: 'more-file-systems', category: 'Connect', icon: '/icons/cloud.svg' },
    { id: 'windows-linux', category: 'Connect', icon: '/icons/monitor.svg' },
    // AI, the rest
    { id: 'ai-batch', category: 'AI', icon: '/icons/zap.svg' },
    { id: 'ai-tell-me', category: 'AI', icon: '/icons/message-circle-question-mark.svg' },
    // Extras
    { id: 'git-browser', category: 'Extras', icon: '/icons/git-branch.svg' },
    { id: 'download-notifications', category: 'Extras', icon: '/icons/bell.svg' },
    { id: 'disk-space-visualizer', category: 'Extras', icon: '/icons/chart-pie.svg' },
    { id: 'plugins', category: 'Extras', icon: '/icons/puzzle.svg' },
]

// Completeness check: the page must place every JSON feature exactly once.
const placedIds = cards.map((card) => card.id)
const jsonIds = features.map((feature) => feature.id)
const missing = jsonIds.filter((id) => !placedIds.includes(id))
const unknown = placedIds.filter((id) => !jsonIds.includes(id))
const dupes = placedIds.filter((id, i) => placedIds.indexOf(id) !== i)
if (missing.length || unknown.length || dupes.length) {
    throw new Error(
        `features page out of sync with feature-status.json. Missing: [${missing.join(', ')}], unknown: [${unknown.join(', ')}], duplicated: [${dupes.join(', ')}]`,
    )
}

const idToFeatureMap = new Map<string, Feature>(features.map((feature) => [feature.id, feature]))
const resolved = cards.map((card) => {
    const feature = idToFeatureMap.get(card.id)!
    return { ...card, feature, title: card.title ?? feature.name }
})
---

<Layout
    title="Features - Cmdr"
    description="Everything Cmdr does and how solid each feature is, in one honest list. Full-disk indexing, on-device AI, keyboard-first navigation, and more."
>
    <Header />
    <main class="mx-auto max-w-6xl px-6 pt-32 pb-24">
        <!-- Hero -->
        <header class="mb-14 text-center">
            <h1 class="mb-4 text-3xl font-bold tracking-tight text-[var(--color-text-primary)] md:text-4xl lg:text-5xl">
                What Cmdr can do
            </h1>
            <p class="mx-auto max-w-2xl text-lg text-[var(--color-text-secondary)]">
                Built in Rust, designed around your keyboard. Cmdr is in open beta: every feature carries an honest
                status pill, and hovering a pill explains what the status means.
            </p>
        </header>

        <!-- One bento: every feature, one card each -->
        <div class="grid grid-cols-1 gap-4 [grid-auto-flow:dense] md:grid-cols-2 lg:grid-cols-3">
            {
                resolved.map((card) => (
                    <section
                        id={card.id}
                        class:list={[
                            'flex scroll-mt-24 flex-col gap-2 rounded-2xl border bg-[var(--color-surface)] p-5',
                            card.flagship && 'md:col-span-2',
                            card.feature.status === 'planned'
                                ? 'border-dashed border-[var(--color-border)]'
                                : 'border-[var(--color-border)]',
                        ]}
                    >
                        <div class="flex items-center gap-2.5">
                            <img src={card.icon} alt="" class="size-6" />
                            <h2 class="text-base font-semibold text-[var(--color-text-primary)]">{card.title}</h2>
                        </div>
                        <p class="flex-1 text-sm text-[var(--color-text-secondary)]">
                            {card.flagship ? card.blurb : card.feature.note}
                        </p>
                        <div class="mt-1 flex flex-wrap items-center gap-2">
                            <span
                                class="rounded-full bg-[var(--color-accent)]/10 px-2.5 py-1 text-xs font-medium whitespace-nowrap text-[var(--color-accent-text)]"
                            >
                                {card.category}
                            </span>
                            <StatusPill status={card.feature.status} link={false} />
                            {card.feature.issueUrl && (
                                <a
                                    href={card.feature.issueUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-xs text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                                >
                                    Track on GitHub
                                </a>
                            )}
                        </div>
                    </section>
                ))
            }
        </div>

        <p class="mt-10 text-center text-sm text-[var(--color-text-tertiary)]">
            Found something rough that's not listed? <a
                href="https://github.com/vdavid/cmdr/issues"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                >Report an issue</a
            > and it gets fixed faster. For timing, see the <a
                href="/roadmap"
                class="text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                >roadmap</a
            >.
        </p>

        <!-- Download CTA -->
        <div class="mt-20 text-center">
            <h2 class="mb-4 text-2xl font-bold text-[var(--color-text-primary)]">
                Wanna see it for yourself? Get Cmdr now.
            </h2>
            <p class="mb-8 text-[var(--color-text-secondary)]">
                Free forever for personal use. No signup, no trial period.
            </p>
            <div class="mx-auto max-w-xs">
                <DownloadButton variant="card" class="w-full" />
            </div>
            <p class="mt-3 text-sm text-[var(--color-text-tertiary)]">macOS only · Source-available (BSL 1.1)</p>
        </div>

        <!-- Newsletter -->
        <div class="mt-16">
            <NewsletterInlineWrapper label="Get notified about new features and releases:" />
        </div>
    </main>
    <Footer />
</Layout>
