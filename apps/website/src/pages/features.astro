---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import DownloadButton from '../components/DownloadButton.astro'
import NewsletterInlineWrapper from '../components/NewsletterInlineWrapper.astro'
import StatusPill from '../components/StatusPill.astro'
import { features, type Feature } from '../lib/feature-status'

/**
 * Presentation map over the repo-root `feature-status.json`: one continuous list,
 * grouped by capability theme (never by status; the pills carry the state). Flagship
 * cards span the full row and carry a trimmed blurb; the rest render the JSON's honest
 * one-line note. The completeness check below fails the build when the JSON and this
 * map drift, so a new feature can't silently miss the page.
 */
interface CardSpec {
    id: string
    flagship?: boolean
    icon?: string
    /** Marketing title override; defaults to the JSON name. */
    title?: string
    /** Flagship-only: 2-3 sentence blurb. Non-flagship cards render the JSON note. */
    blurb?: string
}

const themes: { name: string; cards: CardSpec[] }[] = [
    {
        name: 'Find anything',
        cards: [
            {
                id: 'full-disk-index',
                flagship: true,
                icon: '/icons/database.svg',
                title: 'Live full-disk index',
                blurb: 'Indexes your whole drive in about 4 minutes, then stays current through real-time file system events. Folder sizes show right in the listing, and a background verifier quietly fixes any drift.',
            },
            {
                id: 'search',
                flagship: true,
                icon: '/icons/search.svg',
                title: 'Smart search',
                blurb: 'Find files by describing them: "that PDF contract from last month." AI turns your words into structured filters, and Rust runs the actual search across millions of indexed entries in well under a second.',
            },
            { id: 'go-to-path' },
        ],
    },
    {
        name: 'AI that stays yours',
        cards: [
            {
                id: 'local-ai',
                flagship: true,
                icon: '/icons/sparkles.svg',
                title: 'Private LLM included',
                blurb: 'Cmdr ships with a 3B language model that runs entirely on your Mac (Apple Silicon), so nothing leaves your machine. Want more power? Connect OpenAI, Anthropic, Google, Groq, or any OpenAI-compatible endpoint.',
            },
            { id: 'ai-rename', icon: '/icons/brain.svg' },
            { id: 'ai-batch', icon: '/icons/zap.svg' },
            { id: 'ai-tell-me' },
        ],
    },
    {
        name: 'Core file management',
        cards: [
            {
                id: 'file-explorer',
                flagship: true,
                icon: '/icons/folder.svg',
                title: 'Dual-pane explorer',
                blurb: 'Two panes, tabs, and virtual scrolling that opens a 100,000-file folder in about 4 seconds with icons, sizes, and dates. Big folders stream in progressively while the UI stays responsive throughout.',
            },
            { id: 'file-operations' },
            { id: 'file-viewer' },
            { id: 'tabs' },
            { id: 'drag-and-drop' },
            { id: 'select-files' },
            { id: 'archives' },
        ],
    },
    {
        name: 'Keyboard-first',
        cards: [
            {
                id: 'keyboard-shortcuts',
                flagship: true,
                icon: '/icons/keyboard.svg',
                title: 'Keyboard-first everything',
                blurb: 'Navigate, select, copy, move, and rename without touching the mouse. Every shortcut is customizable, scope-aware, and conflict-checked, and menu accelerators follow your changes.',
            },
            { id: 'command-palette' },
        ],
    },
    {
        name: 'Beyond your Mac',
        cards: [
            {
                id: 'network-drives',
                flagship: true,
                icon: '/icons/server.svg',
                blurb: 'Browse NAS shares and connect with fast direct SMB transfers. Passwords go in the macOS Keychain, not in config files.',
            },
            { id: 'android-devices' },
            { id: 'more-file-systems' },
            { id: 'windows-linux' },
        ],
    },
    {
        name: 'Power tools',
        cards: [
            { id: 'git-browser' },
            { id: 'download-notifications' },
            { id: 'plugins' },
            { id: 'disk-space-visualizer' },
        ],
    },
]

// Completeness check: the page must place every JSON feature exactly once.
const placedIds = themes.flatMap((theme) => theme.cards.map((card) => card.id))
const jsonIds = features.map((feature) => feature.id)
const missing = jsonIds.filter((id) => !placedIds.includes(id))
const unknown = placedIds.filter((id) => !jsonIds.includes(id))
const dupes = placedIds.filter((id, i) => placedIds.indexOf(id) !== i)
if (missing.length || unknown.length || dupes.length) {
    throw new Error(
        `features page out of sync with feature-status.json. Missing: [${missing.join(', ')}], unknown: [${unknown.join(', ')}], duplicated: [${dupes.join(', ')}]`,
    )
}

const idToFeatureMap = new Map<string, Feature>(features.map((feature) => [feature.id, feature]))
const resolve = (card: CardSpec) => {
    const feature = idToFeatureMap.get(card.id)!
    return { ...card, feature, title: card.title ?? feature.name }
}
---

<Layout
    title="Features - Cmdr"
    description="Everything Cmdr does and how solid each feature is, in one honest list. Full-disk indexing, on-device AI, keyboard-first navigation, and more."
>
    <Header />
    <main class="mx-auto max-w-5xl px-6 pt-32 pb-24">
        <!-- Hero -->
        <header class="mb-16 text-center">
            <h1 class="mb-4 text-3xl font-bold tracking-tight text-[var(--color-text-primary)] md:text-4xl lg:text-5xl">
                What Cmdr can do
            </h1>
            <p class="mx-auto max-w-2xl text-lg text-[var(--color-text-secondary)]">
                Built in Rust, designed around your keyboard. Cmdr is in open beta: every feature below carries an
                honest status pill, and hovering a pill explains what the status means.
            </p>
        </header>

        <!-- Feature list, grouped by capability -->
        <div class="space-y-16">
            {
                themes.map((theme) => (
                    <section>
                        <h2 class="mb-5 text-2xl font-semibold text-[var(--color-text-primary)]">{theme.name}</h2>
                        <div class="grid gap-4 md:grid-cols-2">
                            {theme.cards.map(resolve).map((card) => (
                                <section
                                    id={card.id}
                                    class:list={[
                                        'scroll-mt-24 rounded-2xl border bg-[var(--color-surface)]',
                                        card.flagship ? 'p-8 md:col-span-2' : 'p-5',
                                        card.feature.status === 'planned'
                                            ? 'border-dashed border-[var(--color-border)]'
                                            : 'border-[var(--color-border)]',
                                    ]}
                                >
                                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                                        {card.icon && <img src={card.icon} alt="" class="size-7" />}
                                        <h3
                                            class:list={[
                                                'font-semibold text-[var(--color-text-primary)]',
                                                card.flagship ? 'text-xl' : 'text-base',
                                            ]}
                                        >
                                            {card.title}
                                        </h3>
                                        <StatusPill status={card.feature.status} link={false} />
                                        {card.feature.issueUrl && (
                                            <a
                                                href={card.feature.issueUrl}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="text-xs text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                                            >
                                                Track on GitHub
                                            </a>
                                        )}
                                    </div>
                                    <p
                                        class:list={[
                                            'text-[var(--color-text-secondary)]',
                                            card.flagship ? 'mt-3' : 'mt-2 text-sm',
                                        ]}
                                    >
                                        {card.flagship ? card.blurb : card.feature.note}
                                    </p>
                                </section>
                            ))}
                        </div>
                    </section>
                ))
            }
        </div>

        <p class="mt-10 text-center text-sm text-[var(--color-text-tertiary)]">
            Found something rough that's not listed? <a
                href="https://github.com/vdavid/cmdr/issues"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                >Report an issue</a
            > and it gets fixed faster. For timing, see the <a
                href="/roadmap"
                class="text-[var(--color-accent-text)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]"
                >roadmap</a
            >.
        </p>

        <!-- Download CTA -->
        <div class="mt-20 text-center">
            <h2 class="mb-4 text-2xl font-bold text-[var(--color-text-primary)]">
                Wanna see it for yourself? Get Cmdr now.
            </h2>
            <p class="mb-8 text-[var(--color-text-secondary)]">
                Free forever for personal use. No signup, no trial period.
            </p>
            <div class="mx-auto max-w-xs">
                <DownloadButton variant="card" class="w-full" />
            </div>
            <p class="mt-3 text-sm text-[var(--color-text-tertiary)]">macOS only · Source-available (BSL 1.1)</p>
        </div>

        <!-- Newsletter -->
        <div class="mt-16">
            <NewsletterInlineWrapper label="Get notified about new features and releases:" />
        </div>
    </main>
    <Footer />
</Layout>
