---
// The feature-status page merged into /features (the #status section). This stub
// replaces Astro's `redirects` config entry because the generated redirect page
// emits a lowercase doctype, which html-validate rejects.
const target = '/features'
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="refresh" content={`0;url=${target}`} />
        <meta name="robots" content="noindex" />
        <link rel="canonical" href="https://getcmdr.com/features" />
        <title>Moved to /features</title>
    </head>
    <body>
        <p>This page moved to <a href={target}>the features page</a>.</p>
    </body>
</html>
