---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import Story from '../components/Story.astro'
import Features from '../components/Features.astro'
import Testimonials from '../components/Testimonials.astro'
import Download from '../components/Download.astro'
import Footer from '../components/Footer.astro'
import { version, dmgUrls } from '../lib/release'

const softwareApplicationSchema = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Cmdr',
    description:
        'The fastest two-pane file manager for macOS. Indexes your whole drive in minutes, shows folder sizes everywhere, instant search, keyboard-driven everything. Built in Rust, free for personal use.',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'macOS',
    offers: [
        {
            '@type': 'Offer',
            name: 'Personal',
            price: '0',
            priceCurrency: 'USD',
            description: 'Free forever for personal use',
        },
        {
            '@type': 'Offer',
            name: 'Commercial',
            price: '59',
            priceCurrency: 'USD',
            description: 'Per user per year, commercial use allowed',
        },
        {
            '@type': 'Offer',
            name: 'Perpetual',
            price: '199',
            priceCurrency: 'USD',
            description: 'One-time purchase, commercial use, three years of updates',
        },
    ],
    softwareVersion: version,
    downloadUrl: dmgUrls.universal,
    screenshot: 'https://getcmdr.com/hero/cmdr-hero-frame-dark.webp',
    url: 'https://getcmdr.com',
}

const currentYear = new Date().getFullYear()
const tagline = `Finally, a file manager from ${currentYear}!`
---

<Layout title={`Cmdr - ${tagline}`}>
    <Header />
    <main>
        <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
        <Hero />
        <Story />
        <Features />
        <Testimonials />
        <Download />
    </main>
    <Footer />
</Layout>
