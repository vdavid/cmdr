---
import { ClientRouter } from 'astro:transitions'
import DiscordInvitePopup from '../components/DiscordInvitePopup.astro'

interface Props {
    title: string
    description?: string
    ogImage?: string
}

const {
    title,
    description = 'The fastest two-pane file manager for macOS. Indexes your whole drive in minutes, shows folder sizes everywhere, instant search, keyboard-driven everything. Built in Rust, free for personal use.',
    ogImage = '/og-default.png',
} = Astro.props
---

<!doctype html>
<html lang="en">
    <head>
        <ClientRouter />
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#14130f" media="(prefers-color-scheme: dark)" />
        <meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
        <meta name="color-scheme" content="dark light" />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url.href} />
        {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}

        <!-- Favicon -->
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

        <!-- RSS autodiscovery -->
        <link rel="alternate" type="application/rss+xml" title="Cmdr blog" href="/rss.xml" />

        <!-- Preload self-hosted font for faster FCP -->
        <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-variable.woff2" crossorigin />

        <title>{title}</title>

        <!-- Organization structured data -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'Organization',
                name: 'Cmdr',
                url: 'https://getcmdr.com',
                logo: 'https://getcmdr.com/logo-512.png',
                sameAs: ['https://github.com/vdavid/cmdr'],
            })}
        />

        {/* Apply persisted theme choice before first paint to prevent FOUC */}
        <script is:inline>
            ;(function () {
                try {
                    var t = localStorage.getItem('theme')
                    if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t
                } catch { /* localStorage unavailable */ }
                // Preserve theme across Client Router navigations (register once)
                if (!window.__themeSwapRegistered) {
                    window.__themeSwapRegistered = true
                    document.addEventListener('astro:before-swap', function (e) {
                        var theme = document.documentElement.dataset.theme
                        if (theme) e.newDocument.documentElement.dataset.theme = theme
                    })
                }
            })()
        </script>
        <style is:inline>
            @media (prefers-color-scheme: light) {
                html:not([data-theme='dark']) {
                    background-color: #fafaf8;
                }
            }
            html[data-theme='light'] {
                background-color: #fafaf8;
            }
            html[data-theme='dark'] {
                background-color: #14130f;
            }
        </style>

        {/* Hide newsletter icon before first paint if user already subscribed/dismissed */}
        <script is:inline>
            try {
                if (
                    localStorage.getItem('newsletter-subscribed') === 'true' ||
                    localStorage.getItem('newsletter-dismissed') === 'true' ||
                    localStorage.getItem('newsletter-cta-dismissed') === 'true'
                ) {
                    document.documentElement.classList.add('newsletter-hidden')
                }
            } catch { /* localStorage unavailable */ }
        </script>

        {/* Umami analytics: self-hosted, cookieless */}
        {
            import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
                <script
                    defer
                    src={`${import.meta.env.PUBLIC_UMAMI_HOST}/mami`}
                    data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
                />
            )
        }
    </head>
    <body class="min-h-screen">
        <slot />

        <DiscordInvitePopup />

        {
            /* PostHog: session replay, heatmaps, click tracking.
            Loaded from PostHog's CDN to avoid bundling dompurify (has an unpatched XSS advisory).
            Snippet lives in public/scripts/posthog-init.js (extracted to avoid prettier parse errors). */
        }
        {
            import.meta.env.PUBLIC_POSTHOG_KEY && (
                <script
                    is:inline
                    src="/scripts/posthog-init.js"
                    data-ph-key={import.meta.env.PUBLIC_POSTHOG_KEY}
                    data-ph-host={import.meta.env.PUBLIC_POSTHOG_HOST || 'https://eu.i.posthog.com'}
                />
            )
        }

        {/* First-touch channel attribution, storage-free.

           We attribute downloads to the channel a visitor first arrived from (HN, Reddit, a UTM
           campaign, etc.) WITHOUT any localStorage/sessionStorage/cookie: device storage would count
           as ePrivacy storage and force a consent banner, which the whole site is built to avoid (see
           the cookieless Umami/PostHog setup). So attribution lives purely in URL state:

           - `computeRef()` derives the channel from the CURRENT page only: a `?ref=` already on the URL
             (carried from the landing page, highest priority) → UTM source/campaign → external
             referrer hostname. Same-origin referrers and getcmdr.com itself count as "no referrer".
           - `propagateRefToLinks()` copies the computed ref onto same-origin `<a>` links so it survives
             internal navigation (land on /blog/x via HN, click through to the homepage, download there).
           - `applyRefToDownloadLinks()` appends it to the download endpoint URLs; the server stores it.

           Trade-off: a return visit in a later session has no URL ref and shows as direct/NULL. That's
           fine — this is anonymous aggregate channel attribution, not user-level tracking. */}
        <script is:inline>
            ;(function () {
                window.__cmdrComputeRef = function computeRef() {
                    function normalize(value) {
                        if (!value) return ''
                        return value
                            .toLowerCase()
                            .replace(/[^a-z0-9._:-]/g, '')
                            .slice(0, 120)
                    }
                    try {
                        var params = new URLSearchParams(window.location.search)
                        // A ref carried from the landing page wins, so attribution stays stable across
                        // internal navigation.
                        var existing = normalize(params.get('ref'))
                        if (existing) return existing

                        var utmSource = params.get('utm_source')
                        if (utmSource) {
                            var utmCampaign = params.get('utm_campaign')
                            return normalize(utmCampaign ? utmSource + '-' + utmCampaign : utmSource)
                        }

                        if (document.referrer) {
                            var refUrl = new URL(document.referrer)
                            // Treat same-origin (internal) referrers as "no referrer": only the
                            // external entry point is a channel.
                            if (refUrl.hostname !== window.location.hostname) {
                                return normalize(refUrl.hostname.replace(/^www\./, ''))
                            }
                        }
                    } catch { /* malformed URL / referrer */ }
                    return ''
                }

                // Carry the ref onto same-origin links so it survives internal navigation. Skips
                // anchors, non-http(s) schemes, and links that already carry a `ref` (don't clobber).
                function propagateRefToLinks(ref) {
                    if (!ref) return
                    document.querySelectorAll('a[href]').forEach(function (a) {
                        // Download links get the ref via applyRefToDownloadLinks (they point at the
                        // API origin, not same-origin), so skip them here.
                        if (a.hasAttribute('data-download-link') || a.hasAttribute('data-arch')) return
                        try {
                            var url = new URL(a.href, window.location.href)
                            if (url.origin !== window.location.origin) return
                            if (url.protocol !== 'http:' && url.protocol !== 'https:') return
                            if (url.hash && url.pathname === window.location.pathname && !url.search) return
                            if (url.searchParams.has('ref')) return
                            url.searchParams.set('ref', ref)
                            a.href = url.href
                        } catch { /* skip unparseable hrefs */ }
                    })
                }

                // Append the ref to download endpoint URLs (which carry `?src=website`). Re-run safe:
                // it overwrites any prior ref it set rather than stacking params.
                window.__cmdrApplyRefToDownloadLinks = function applyRefToDownloadLinks(ref) {
                    if (!ref) return
                    document
                        .querySelectorAll('a[data-download-link], [data-download-dropdown] a[data-arch]')
                        .forEach(function (a) {
                            try {
                                var url = new URL(a.href, window.location.href)
                                url.searchParams.set('ref', ref)
                                a.href = url.href
                                // Carry the ref into the Umami "download" click event too.
                                a.dataset.umamiEventRef = ref
                            } catch { /* skip unparseable hrefs */ }
                        })
                }

                function run() {
                    var ref = window.__cmdrComputeRef()
                    if (!ref) return
                    propagateRefToLinks(ref)
                    window.__cmdrApplyRefToDownloadLinks(ref)
                }

                run()
                // Re-run after Client Router swaps so the new page's links get the ref too.
                document.addEventListener('astro:page-load', run)
            })()
        </script>

        <script is:inline>
            ;(function () {
                function applyArch(arch) {
                    document.querySelectorAll('a[data-download-link]').forEach(function (el) {
                        var url = arch === 'aarch64' ? el.dataset.dmgArm : el.dataset.dmgIntel
                        if (url) el.href = url
                        el.dataset.umamiEventArch = arch
                        var size = arch === 'aarch64' ? el.dataset.sizeArm : el.dataset.sizeIntel
                        if (size) {
                            el.querySelectorAll('[data-download-size]').forEach(function (s) {
                                s.textContent = s.textContent.replace(/\d+ MB/, size)
                            })
                        }
                    })
                    document.querySelectorAll('[data-download-dropdown] [data-arch]').forEach(function (el) {
                        if (el.dataset.arch === arch) {
                            el.dataset.recommended = 'true'
                        }
                    })
                    // applyArch overwrites the main download link's href (dropping any ref we appended),
                    // so re-apply the ref afterward. Safe to call with an empty ref (no-op).
                    if (window.__cmdrApplyRefToDownloadLinks && window.__cmdrComputeRef) {
                        window.__cmdrApplyRefToDownloadLinks(window.__cmdrComputeRef())
                    }
                }

                // Detect arch synchronously to avoid flash of universal binary on first paint.
                // WebGL renderer reports "Apple M1/M2/GPU" on Apple Silicon, "Intel/AMD" on Intel Macs.
                // Falls back to localStorage cache from a previous async detection.
                function detectArchSync() {
                    try {
                        var canvas = document.createElement('canvas')
                        var gl = canvas.getContext('webgl')
                        if (!gl) return null
                        var ext = gl.getExtension('WEBGL_debug_renderer_info')
                        if (!ext) return null
                        var renderer = gl.getParameter(ext.UNMASKED_RENDERER_WEBGL)
                        if (/Apple M|Apple GPU/.test(renderer)) return 'aarch64'
                        if (/Intel|AMD/.test(renderer)) return 'x86_64'
                    } catch { /* WebGL unavailable */ }
                    return null
                }

                var syncArch = detectArchSync()
                if (!syncArch) {
                    try {
                        syncArch = localStorage.getItem('cmdr-arch')
                    } catch {
                        /* localStorage unavailable */
                    }
                }
                if (syncArch) applyArch(syncArch)

                // Detect arch async and update cache for next visit
                if (!navigator.userAgentData) return
                navigator.userAgentData
                    .getHighEntropyValues(['architecture'])
                    .then(function (ua) {
                        var arch = ua.architecture === 'arm' ? 'aarch64' : ua.architecture === 'x86' ? 'x86_64' : null
                        if (!arch) return
                        try {
                            localStorage.setItem('cmdr-arch', arch)
                        } catch {
                            /* localStorage unavailable */
                        }
                        applyArch(arch)
                    })
                    .catch(function () {})
            })()
        </script>
    </body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
