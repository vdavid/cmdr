# Paddle checkout configuration
# Get these from https://sandbox-vendors.paddle.com (sandbox) or https://vendors.paddle.com (live)

# Client-side token for Paddle.js (starts with "test_" for sandbox, "live_" for production)
PUBLIC_PADDLE_CLIENT_TOKEN=test_xxx

# Price IDs for each product tier
PUBLIC_PADDLE_PRICE_ID_COMMERCIAL_SUBSCRIPTION=pri_xxx
PUBLIC_PADDLE_PRICE_ID_COMMERCIAL_PERPETUAL=pri_xxx

# Set to "live" for production, "sandbox" for testing
PUBLIC_PADDLE_ENVIRONMENT=sandbox

# Newsletter (Listmonk)
# Get the list UUID from the Listmonk admin UI: Lists > your list > Settings
PUBLIC_LISTMONK_LIST_UUID=

# Download tracking redirect
# Routes downloads through the API server for server-side analytics.
# Production: https://api.getcmdr.com — downloads become /download/{version}/{arch}
# Leave empty to link directly to GitHub Releases (useful for dev).
PUBLIC_DOWNLOAD_BASE_URL=

# Umami analytics (self-hosted, cookieless, proxied through getcmdr.com/u/)
# Leave PUBLIC_UMAMI_WEBSITE_ID empty to disable tracking (for example, in dev env)
PUBLIC_UMAMI_HOST=/u
PUBLIC_UMAMI_WEBSITE_ID=

# Umami API credentials to be used in the dev env for scripts (not used by the website in prod!)
UMAMI_API_URL=https://your-umami-instance.example.com
UMAMI_USERNAME=admin
UMAMI_PASSWORD='your-password-here'

# PostHog (session replay, heatmaps, click tracking, proxied through getcmdr.com/ph/)
# Leave PUBLIC_POSTHOG_KEY empty to disable (for example, in dev env)
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=/ph
