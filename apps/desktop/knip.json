{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "treatConfigHintsAsErrors": true,
  "ignoreBinaries": ["rustc", "oxfmt", "pgrep"],
  "ignore": ["src/lib/tauri-commands/**", "src/lib/ipc/bindings.ts"],
  "ignoreUnresolved": ["~icons/.+"],
  "ignoreDependencies": ["oxlint", "@testing-library/svelte", "prettier-plugin-svelte", "@iconify-json/lucide"],
  "ignoreExportsUsedInFile": true,
  "project": ["src/**/*.{ts,svelte}"],
  "svelte": {
    "entry": ["src/routes/**/+page.svelte", "src/routes/**/+layout.svelte"]
  }
}
