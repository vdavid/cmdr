{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 4,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "printWidth": 120,
    "proseWrap": "always",
    "sortPackageJson": false,
    "ignorePatterns": [
        ".svelte-kit/",
        "src-tauri/",
        "build/",
        "dist/",
        "pnpm-lock.yaml",
        "playwright-report/",
        "test-results/",
        "coverage/"
    ]
}
