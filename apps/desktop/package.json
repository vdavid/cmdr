{
  "name": "@cmdr/desktop",
  "version": "0.34.0",
  "description": "",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"a11y_no_noninteractive_element_interactions:ignore,a11y_click_events_have_key_events:ignore,a11y_no_noninteractive_tabindex:ignore,a11y_interactive_supports_focus:ignore,state_referenced_locally:ignore,non_reactive_update:ignore\"",
    "check:no-sync": "svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"a11y_no_noninteractive_element_interactions:ignore,a11y_click_events_have_key_events:ignore,a11y_no_noninteractive_tabindex:ignore,a11y_interactive_supports_focus:ignore,state_referenced_locally:ignore,non_reactive_update:ignore\"",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --compiler-warnings \"a11y_no_noninteractive_element_interactions:ignore,a11y_click_events_have_key_events:ignore,a11y_no_noninteractive_tabindex:ignore,a11y_interactive_supports_focus:ignore,state_referenced_locally:ignore,non_reactive_update:ignore\"",
    "tauri": "node scripts/tauri-wrapper.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e:linux": "./scripts/e2e-linux.sh",
    "test:e2e:linux:build": "./scripts/e2e-linux.sh --build --build-only",
    "test:e2e:linux:shell": "./scripts/e2e-linux.sh --shell",
    "test:e2e:linux:vnc": "./scripts/e2e-linux.sh --vnc",
    "test:e2e:playwright": "npx playwright test --config test/e2e-playwright/playwright.config.ts --project=tauri",
    "test:e2e:playwright:build": "node scripts/tauri-wrapper.ts build --no-bundle --target $(rustc -vV | grep host | cut -d' ' -f2) -- --features playwright-e2e,virtual-mtp",
    "knip": "knip",
    "check:type-drift": "node scripts/check-type-drift.ts",
    "bindings:regen": "cd src-tauri && cargo nextest run --no-fail-fast --run-ignored=ignored-only ipc::tests::export_bindings_test && cd .. && pnpm exec oxfmt src/lib/ipc/bindings.ts",
    "intl:keys": "node scripts/gen-message-keys.ts && pnpm exec oxfmt src/lib/intl/keys.gen.ts",
    "i18n:pseudo": "node scripts/gen-pseudolocale.ts",
    "i18n:check-stale": "node scripts/i18n-check-stale.ts",
    "i18n:check-parity": "node scripts/i18n-check-parity.ts",
    "i18n:check-icu": "node scripts/i18n-check-icu.ts",
    "i18n:check-plural": "node scripts/i18n-check-plural.ts",
    "i18n:check-coverage": "node scripts/i18n-check-coverage.ts",
    "i18n:check-dont-translate": "node scripts/i18n-check-dont-translate.ts",
    "i18n:capture": "node scripts/i18n-capture.ts",
    "i18n:couple": "node scripts/couple-screenshots.ts",
    "i18n:shots": "node scripts/i18n-capture.ts --build && node scripts/couple-screenshots.ts",
    "i18n:overflow": "node scripts/i18n-capture.ts --build --locale en-XA"
  },
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@ark-ui/svelte": "^5.22.1",
    "@chenglou/pretext": "^0.0.8",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@logtape/logtape": "^2.2.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "intl-messageformat": "^11.2.12",
    "snarkdown": "2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "1.2.117",
    "@playwright/test": "^1.61.1",
    "@srsholmes/tauri-playwright": "^0.4.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "oxlint": "^1.74.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "3.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte-eslint-parser": "^1.8.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "unplugin-icons": "23.0.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
