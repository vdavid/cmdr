{
  "name": "@cmdr/desktop",
  "version": "0.22.0",
  "description": "",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"a11y_no_noninteractive_element_interactions:ignore,a11y_click_events_have_key_events:ignore,a11y_no_noninteractive_tabindex:ignore,a11y_interactive_supports_focus:ignore,state_referenced_locally:ignore,non_reactive_update:ignore\"",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --compiler-warnings \"a11y_no_noninteractive_element_interactions:ignore,a11y_click_events_have_key_events:ignore,a11y_no_noninteractive_tabindex:ignore,a11y_interactive_supports_focus:ignore,state_referenced_locally:ignore,non_reactive_update:ignore\"",
    "tauri": "node scripts/tauri-wrapper.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e:linux": "./scripts/e2e-linux.sh",
    "test:e2e:linux:build": "docker build -t cmdr-e2e -f test/e2e-linux/docker/Dockerfile test/e2e-linux/docker",
    "test:e2e:linux:shell": "./scripts/e2e-linux.sh --shell",
    "test:e2e:linux:vnc": "./scripts/e2e-linux.sh --vnc",
    "test:e2e:playwright": "npx playwright test --config test/e2e-playwright/playwright.config.ts --project tauri",
    "test:e2e:playwright:build": "node scripts/tauri-wrapper.js build --no-bundle --target $(rustc -vV | grep host | cut -d' ' -f2) -- --features playwright-e2e,virtual-mtp",
    "knip": "knip",
    "check:type-drift": "tsx scripts/check-type-drift.ts",
    "bindings:regen": "cd src-tauri && cargo nextest run --no-fail-fast --run-ignored=ignored-only ipc::tests::export_bindings_test && cd .. && pnpm exec oxfmt src/lib/ipc/bindings.ts"
  },
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@ark-ui/svelte": "^5.21.2",
    "@chenglou/pretext": "^0.0.6",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@logtape/logtape": "^2.0.5",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "snarkdown": "2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "1.2.103",
    "@playwright/test": "^1.59.1",
    "@srsholmes/tauri-playwright": "^0.2.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.7.0",
    "oxlint": "^1.61.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "3.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "unplugin-icons": "23.0.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
