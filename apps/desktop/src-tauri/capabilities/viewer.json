{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "viewer",
    "description": "Capability for file viewer windows",
    "windows": [
        "viewer-*"
    ],
    "permissions": [
        "core:window:allow-close",
        "core:window:allow-set-title",
        "core:window:allow-set-focus",
        "core:event:default",
        "clipboard-manager:allow-write-text",
        "dialog:allow-save"
    ]
}
