# Umami (self-hosted web analytics)
# Get credentials from your Umami instance
UMAMI_API_URL=https://your-umami-instance.example.com
UMAMI_USERNAME=admin
UMAMI_PASSWORD=your-password
UMAMI_WEBSITE_ID=your-website-uuid
UMAMI_BLOG_WEBSITE_ID=your-blog-website-uuid
UMAMI_PRVW_WEBSITE_ID=your-prvw-website-uuid

# Paddle (payment provider)
# Get from https://vendors.paddle.com > Developer Tools > API Keys
PADDLE_API_KEY_LIVE=your-paddle-live-api-key

# PostHog (product analytics)
# Personal API key (phx_...), not the public project key (phc_...)
POSTHOG_API_KEY=phx_your-personal-api-key
POSTHOG_PROJECT_ID=123456
POSTHOG_API_URL=https://eu.posthog.com

# GitHub (release download counts)
# Optional. Without it, GitHub API rate limits apply (60 req/hour)
GITHUB_TOKEN=ghp_your-token

# API server (activation stats)
# Admin token configured on the API server
LICENSE_SERVER_ADMIN_TOKEN=your-admin-token

# Optional: point the worker-backed sources (downloads, update activity, feedback, errors) at a local
# `wrangler dev` instead of production. Leave unset for normal use. For local QA against seeded data,
# see "Local QA against a local worker" in CLAUDE.md.
# WORKER_BASE_URL=http://127.0.0.1:18900
