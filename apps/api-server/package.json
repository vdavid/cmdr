{
  "name": "@cmdr/api-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "setup-infra": "./scripts/setup-cf-infra.sh",
    "generate-keys": "node scripts/generate-keys.js",
    "test:checkout": "node test/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.15",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
