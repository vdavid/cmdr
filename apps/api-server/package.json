{
  "name": "@cmdr/api-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "setup-infra": "./scripts/setup-cf-infra.sh",
    "generate-keys": "node scripts/generate-keys.js",
    "test:checkout": "node test/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.30",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.1"
  }
}
