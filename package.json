{
    "name": "cmdr",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "RUST_LOG=smb=warn,sspi=warn,${RUST_LOG:-info} pnpm --filter @cmdr/desktop tauri dev",
        "dev:ai-debug": "RUST_LOG=smb=warn,sspi=warn,cmdr_lib::ai=debug,${RUST_LOG:-info} pnpm --filter @cmdr/desktop tauri dev",
        "build": "pnpm --filter @cmdr/desktop tauri build",
        "dev:website": "pnpm --filter @cmdr/website dev",
        "build:website": "pnpm --filter @cmdr/website build",
        "dev:dashboard": "pnpm --filter @cmdr/analytics-dashboard dev",
        "build:dashboard": "pnpm --filter @cmdr/analytics-dashboard build",
        "dev:api-server": "pnpm --filter @cmdr/api-server dev",
        "deploy:api-server": "pnpm --filter @cmdr/api-server deploy",
        "check": "./scripts/check.sh"
    },
    "pnpm": {
        "overrides": {
            "serialize-javascript": ">=7.0.3",
            "lodash": ">=4.17.23",
            "cookie": ">=0.7.0",
            "tmp": ">=0.2.4"
        },
        "onlyBuiltDependencies": [
            "edgedriver",
            "geckodriver",
            "sharp",
            "workerd"
        ]
    },
    "devDependencies": {
        "oxfmt": "^0.42.0"
    }
}