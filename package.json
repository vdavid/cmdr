{
  "name": "cmdr",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @cmdr/desktop tauri dev",
    "dev:ai-debug": "RUST_LOG=cmdr_lib::ai=debug,${RUST_LOG:-info} pnpm --filter @cmdr/desktop tauri dev",
    "build": "pnpm --filter @cmdr/desktop tauri build",
    "dev:website": "pnpm --filter @cmdr/website dev",
    "build:website": "pnpm --filter @cmdr/website build",
    "dev:dashboard": "pnpm --filter @cmdr/analytics-dashboard dev",
    "build:dashboard": "pnpm --filter @cmdr/analytics-dashboard build",
    "dev:api-server": "pnpm --filter @cmdr/api-server dev",
    "deploy:api-server": "pnpm --filter @cmdr/api-server deploy",
    "i18n:pseudo": "pnpm --filter @cmdr/desktop i18n:pseudo",
    "i18n:check-stale": "pnpm --filter @cmdr/desktop i18n:check-stale",
    "i18n:capture": "pnpm --filter @cmdr/desktop i18n:capture",
    "i18n:couple": "pnpm --filter @cmdr/desktop i18n:couple",
    "i18n:shots": "pnpm --filter @cmdr/desktop i18n:shots",
    "i18n:overflow": "pnpm --filter @cmdr/desktop i18n:overflow",
    "check": "./scripts/check.sh"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0"
  },
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "pnpm": ">=11"
  }
}
