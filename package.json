{
    "name": "cmdr",
    "private": true,
    "packageManager": "pnpm@10.30.0",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "RUST_LOG=smb=warn,sspi=warn,${RUST_LOG:-info} pnpm --filter @cmdr/desktop tauri dev",
        "dev:ai-debug": "CMDR_REAL_AI=1 RUST_LOG=smb=warn,sspi=warn,cmdr_lib::ai=debug,${RUST_LOG:-info} pnpm --filter @cmdr/desktop tauri dev",
        "build": "pnpm --filter @cmdr/desktop tauri build",
        "dev:website": "pnpm --filter @cmdr/website dev",
        "build:website": "pnpm --filter @cmdr/website build",
        "dev:license-server": "pnpm --filter @cmdr/license-server dev",
        "deploy:license-server": "pnpm --filter @cmdr/license-server deploy",
        "check": "./scripts/check.sh"
    },
    "pnpm": {
        "overrides": {
            "rollup": ">=4.59.0",
            "svelte": ">=5.53.5",
            "fast-xml-parser": ">=5.3.8"
        },
        "onlyBuiltDependencies": [
            "edgedriver",
            "geckodriver",
            "sharp",
            "workerd"
        ]
    }
}